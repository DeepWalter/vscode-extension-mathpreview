{
  "name": "mathpreview",
  "displayName": "Math Preview",
  "publisher": "mathpreview",
  "description": "Render LaTeX math formulas in hover popups",
  "version": "0.1.0",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/DeepWalter/vscode-extension-mathpreview"
  },
  "bugs": {
    "url": "https://github.com/DeepWalter/vscode-extension-mathpreview/issues"
  },
  "homepage": "https://github.com/DeepWalter/vscode-extension-mathpreview#readme",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mathpreview.clearCache",
        "title": "Math Preview: Clear Render Cache"
      }
    ],
    "configuration": {
      "title": "Math Preview",
      "properties": {
        "mathpreview.languages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "python"
          ],
          "description": "Language IDs for which math rendering is enabled (e.g. \"python\", \"markdown\", \"latex\", \"r\")."
        },
        "mathpreview.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable math rendering in hover popups."
        },
        "mathpreview.cacheSize": {
          "type": "number",
          "default": 200,
          "description": "Maximum number of rendered formulas to cache in memory."
        },
        "mathpreview.sizeScale": {
          "type": "number",
          "default": 1,
          "minimum": 0.25,
          "maximum": 4,
          "description": "Scale factor for rendered formula size (1.0 = default). Increase for larger popups, decrease for smaller."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@resvg/resvg-wasm": "^2.6.2",
    "mathjax-full": "^3.2.2"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}